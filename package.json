{
  "name": "yike",
  "version": "0.1.0",
  "private": true,
  "description": "Yike.ng — Nigerian housing marketplace",
  "homepage": "https://yike.ng",
  "scripts": {
    "optimize:brand": "node scripts/optimize-brand-assets.mjs",
    "optimize:crew": "node scripts/optimize-crew-app-icon.mjs",
    "generate:crew-twa": "node scripts/generate-crew-twa-assets.mjs",
    "store:assets": "node scripts/generate-store-assets.mjs",
    "twa:init": "cd twa && npx @bubblewrap/cli init --manifest=https://yike.ng/manifest.json",
    "twa-staff:init": "cd twa-staff && npx @bubblewrap/cli init --manifest=https://yike.ng/staff/manifest.json",
    "twa-staff:build": "npm run generate:crew-twa && bash twa-staff/build-release.sh",
    "heroes:generate": "node scripts/generate-hero-images.mjs",
    "careers:publish-content-seo": "node scripts/publish-content-seo-writer-job.mjs",
    "db:push": "bash scripts/apply-supabase-migrations.sh",
    "db:status": "supabase migration list",
    "admin:ensure": "node scripts/ensure-admin-user.mjs",
    "reviewer:ensure": "node scripts/ensure-reviewer-users.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed:sql": "tsx scripts/seed-supabase.ts --sql",
    "seed": "tsx scripts/seed-supabase.ts",
    "domain:dns": "bash scripts/setup-yike-domain-dns.sh",
    "domain:verify": "bash scripts/verify-yike-domain.sh",
    "email:assets": "node scripts/generate-email-assets.mjs && npx tsx scripts/render-email-previews.ts",
    "notifications:test": "node scripts/test-sendchamp.mjs",
    "store:capture": "node scripts/capture-play-screenshots.mjs",
    "store:capture:1440": "SCREENSHOT_WIDTH=1440 SCREENSHOT_HEIGHT=3200 node scripts/capture-play-screenshots.mjs",
    "store:capture:tablet-7": "TABLET_SIZE=7 node scripts/capture-play-tablet-screenshots.mjs",
    "store:capture:tablet-10": "TABLET_SIZE=10 node scripts/capture-play-tablet-screenshots.mjs",
    "store:capture:tablet": "TABLET_SIZE=both node scripts/capture-play-tablet-screenshots.mjs",
    "test:auth": "tsx scripts/test-auth-security.ts",
    "test:review-memory": "tsx scripts/test-review-memory.ts",
    "test:outcome-intelligence": "tsx scripts/test-outcome-intelligence.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.107.0",
    "@vercel/analytics": "^2.0.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.4",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "playwright": "^1.52.0",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
