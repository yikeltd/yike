# =============================================================================
# Yike — environment variables
# Copy to .env.local for dev. Set the same keys in Vercel → yikeprojects/yike → Settings → Environment Variables.
# =============================================================================

# --- Required (Vercel Production + Preview + Development) ---
# Supabase → Project Settings → API
# https://supabase.com/dashboard/project/gyxemepnrkwxocgzfbeo/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://gyxemepnrkwxocgzfbeo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# --- Required on Vercel for signup, phone OTP, admin APIs (server-only — never NEXT_PUBLIC_) ---
# Supabase → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Phone OTP (Sendchamp — server-only) ---
# https://app.sendchamp.com → API keys
SENDCHAMP_API_KEY=your-sendchamp-api-key
# Alias accepted if dashboard key was saved as SENDCHAMP_PUBLIC_KEY on Vercel
SENDCHAMP_PUBLIC_KEY=
SENDCHAMP_SMS_SENDER=Yike
SENDCHAMP_WHATSAPP_SENDER=Yike
# Optional — append ?secret=... to webhook URL or send x-yike-webhook-secret header
SENDCHAMP_WEBHOOK_SECRET=your-webhook-secret

# --- Transactional email (Resend — server-only) ---
# https://resend.com/api-keys
# 1. Add domain send.yike.ng (or yike.ng) in Resend → Domains
# 2. Add DKIM/MX/TXT records in Cloudflare DNS
# 3. Verify domain, then use hello@yike.ng as from address
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=Yike <hello@yike.ng>

# --- Agent NIN verification (optional — Dojah recommended for MVP) ---
# DOJAH_APP_ID=your-dojah-app-id
# DOJAH_SECRET_KEY=your-dojah-secret-key
# ENCRYPTION_SECRET=32-char-minimum-secret-for-nin-encryption

# --- Search engine verification (optional — paste meta tag content from consoles) ---
# Google Search Console → HTML tag method
GOOGLE_SITE_VERIFICATION=
# Bing Webmaster Tools → meta tag
BING_SITE_VERIFICATION=

# --- Local scripts only (seed) — do not add to Vercel unless running seeds in CI ---
# SUPABASE_URL=https://gyxemepnrkwxocgzfbeo.supabase.co

# --- Auto-set by Vercel (do not add manually) ---
# NODE_ENV=production

# --- Supabase Auth redirect URLs (dashboard, not env vars) ---
# Authentication → URL configuration:
#   Site URL: https://yike.ng
#   Redirect URLs: https://yike.ng/auth/callback, http://localhost:3000/auth/callback
