# =============================================================================
# Yike — environment variables
# Copy to .env.local for dev. Set the same keys in Vercel → yikeprojects/yike → Settings → Environment Variables.
# =============================================================================

# --- Required (Vercel Production + Preview + Development) ---
# Supabase → Project Settings → API
# https://supabase.com/dashboard/project/gyxemepnrkwxocgzfbeo/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://gyxemepnrkwxocgzfbeo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# --- Required on Vercel for signup + admin APIs (server-only — never NEXT_PUBLIC_) ---
# Supabase → Project Settings → API → service_role (secret) or secret API key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Phone OTP server token (server-only; auto-generated — must match Supabase yike_internal_config) ---
YIKE_OTP_SERVER_TOKEN=your-otp-server-token

# --- Phone OTP (Sendchamp only — server-only) ---
# Launch defaults: phone/SMS/WhatsApp OTP off; email OTP on (see Auth verification flags below).
# https://app.sendchamp.com → Account Settings → Public access key + Live Base URL
# Docs: https://sendchamp.readme.io/reference/introduction
SENDCHAMP_PUBLIC_KEY=your-sendchamp-public-access-key
SENDCHAMP_LIVE_BASE_URL=https://api.sendchamp.com/api/v1
SENDCHAMP_WEBHOOK_URL=https://yike.ng/api/webhooks/sendchamp
# Optional legacy key — only if Sendchamp provides a separate secret later
# SENDCHAMP_API_KEY=
# Approved SMS sender ID (production: Yike, non_dnd route)
SENDCHAMP_SMS_SENDER=Yike
# WhatsApp sender MUST be an international phone number (234…), not a brand name
SENDCHAMP_WHATSAPP_SENDER=2348035143299

# --- Auth verification flags (launch: email-first) ---
# Server-only — re-enable phone OTP after sender IDs / provider stability
ENABLE_PHONE_OTP=false
ENABLE_SMS_OTP=false
ENABLE_WHATSAPP_OTP=false
ENABLE_EMAIL_OTP=true
# Client signup UI — mirrors ENABLE_PHONE_OTP for phone verification step
NEXT_PUBLIC_ENABLE_PHONE_OTP=false

# --- WhatsApp lead gateway (server-only) ---
# Route listing WhatsApp taps through Yike first → /l/[ref] handoff → agent
YIKE_LEAD_GATEWAY_ENABLED=true
# Official Yike WhatsApp line (defaults to SENDCHAMP_WHATSAPP_SENDER if unset)
YIKE_WHATSAPP_NUMBER=2348035143299
# Phased direct-to-agent routing (launch default: off — Yike-first concierge)
ENABLE_DIRECT_AGENT_WHATSAPP=false
# Direct agent phone calls via call icon (launch default: off — WhatsApp-first)
ENABLE_DIRECT_AGENT_CALLS=false
# WhatsApp Cloud API auto-reply to leads (launch default: off — human concierge)
ENABLE_WHATSAPP_LEAD_AUTOREPLY=false
# Agent pay-per-lead billing deductions (launch default: off — records charge_amount only)
ENABLE_AGENT_LEAD_BILLING=false
# System default lead price in NGN when agent/listing price unset (optional)
# YIKE_DEFAULT_LEAD_PRICE=500
# Optional — append ?secret=... to webhook URL or send x-yike-webhook-secret header
# SENDCHAMP_WEBHOOK_SECRET=your-webhook-secret

# --- Transactional email (Resend — server-only) ---
# https://resend.com/api-keys
# 1. Add domain send.yike.ng (or yike.ng) in Resend → Domains
# 2. Add DKIM/MX/TXT records in Cloudflare DNS
# 3. Verify domain, then use hello@yike.ng as from address
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=Yike <hello@yike.ng>
# Internal moderation alerts (defaults to hello@yike.ng)
ADMIN_ALERT_EMAIL=hello@yike.ng

# --- Agent NIN verification (optional — Dojah recommended for MVP) ---
# DOJAH_APP_ID=your-dojah-app-id
# DOJAH_SECRET_KEY=your-dojah-secret-key
# ENCRYPTION_SECRET=32-char-minimum-secret-for-nin-encryption

# --- Search engine verification (optional — paste meta tag content from consoles) ---
# Google Search Console → HTML tag method
GOOGLE_SITE_VERIFICATION=
# Bing Webmaster Tools → meta tag
# Optional override — default is baked into layout for yike.ng
BING_SITE_VERIFICATION=02902039559EB4CCB652E858CBFF27B8

# --- Local scripts only (seed) — do not add to Vercel unless running seeds in CI ---
# SUPABASE_URL=https://gyxemepnrkwxocgzfbeo.supabase.co

# --- Scheduled jobs (Vercel Cron / external) — server-only ---
# GET /api/cron/trust-quality with Authorization: Bearer <CRON_SECRET>
CRON_SECRET=your-cron-secret

# --- Auto-set by Vercel (do not add manually) ---
# NODE_ENV=production

# --- Supabase Auth redirect URLs (dashboard, not env vars) ---
# Authentication → URL configuration:
#   Site URL: https://yike.ng
#   Redirect URLs: https://yike.ng/auth/callback, http://localhost:3000/auth/callback
